# Normalize line endings so the repo doesn't churn LF/CRLF between contributors.
# Git stores everything as LF; on Windows checkouts CRLF is converted on the way out.

* text=auto eol=lf

# C# source: explicit LF.
*.cs text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.slnx text eol=lf
*.razor text eol=lf
*.cshtml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.runsettings text eol=lf
*.editorconfig text eol=lf

# Shell scripts must be LF.
*.sh text eol=lf

# PowerShell scripts can be CRLF (Windows tooling expects it).
*.ps1 text eol=crlf

# Treat binary files literally.
*.nupkg binary
*.snupkg binary
*.dll binary
*.exe binary
*.pdb binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
